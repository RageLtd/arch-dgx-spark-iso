{
  "kernels": ["linux-dgx-spark"],
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "uki": false,
    "removable": false
  },
  "packages": ["git", "base-devel", "limine", "efibootmgr"],
  "custom_commands": [
    "bootctl remove",
    "bash /root/limine-hooks/install-limine.sh"
  ],
  "swap": false,
  "ntp": true,
  "timezone": "UTC",
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  }
}
